# TOSRC 环境变量配置示例
# 复制此文件为 .env 并修改配置值

# ==========================================
# 安全配置 (必须修改)
# ==========================================
ADMIN_API_KEY=your-secure-api-key-here

# ==========================================
# CORS 配置
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# ==========================================
# 数据库配置
# ==========================================
# SQLite 数据库路径 (单租户模式)
DATABASE_URL=sqlite:///data/TOSRC.db

# MySQL 配置 (多租户模式)
# DATABASE_URL=mysql://user:password@localhost/TOSRC
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=TOSRC
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=TOSRC

# ==========================================
# Redis 配置 (多租户模式)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==========================================
# 服务配置
# ==========================================
HOST=0.0.0.0
PORT=8080
WORKERS=1

# ==========================================
# 功能开关
# ==========================================
# 是否启用模型引擎
ENABLE_MODEL_ENGINE=true
# 是否启用仿生架构
ENABLE_BIONIC_ARCH=true
# 是否启用仿生缓存
ENABLE_BIONIC_CACHE=false

# ==========================================
# LLM 配置 (可选)
# ==========================================
# OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# ==========================================
# 监控配置
# ==========================================
# 是否启用 Prometheus 指标
ENABLE_METRICS=true
METRICS_PORT=9090
